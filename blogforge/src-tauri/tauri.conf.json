{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BlogForge",
  "version": "0.1.0",
  "identifier": "com.blogforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "BlogForge",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "桌面端博客管理系统",
    "longDescription": "BlogForge 是一款面向个人用户的跨平台桌面博客管理软件，提供从内容创作、本地预览到静态网站发布的完整解决方案。"
  }
}
